# Copy this file to .env and fill in values before starting the server.

# NCBI API key — optional but recommended.
# Register at: https://www.ncbi.nlm.nih.gov/account/
# With a key you get 10 requests/s instead of 3 requests/s.
NCBI_API_KEY=

# Directories used by the pipeline
CACHE_DIR=cache
OUTPUT_DIR=results

# CORS origins for the REST API (comma-separated, or * for all)
CORS_ORIGINS=*
